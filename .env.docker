# Docker Environment Configuration
# Copy this to .env.docker and update values

# Gmail Configuration
GMAIL_USER_EMAIL=your-company@gmail.com
GMAIL_QUERY=subject:RSD

# Document Archive (absolute path on host)
PROJECT_DOCS_PATH=/mnt/project_documents

# LLM Configuration
USE_OLLAMA=false
OPENAI_API_KEY=sk-your-api-key-here

# Email Summary
SUMMARY_RECIPIENT_EMAIL=team@company.com

# RAG Configuration
SIMILARITY_THRESHOLD=0.6
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Logging
LOG_LEVEL=INFO
