# Gmail Configuration
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_USER_EMAIL=your-company@gmail.com
GMAIL_QUERY=subject:RSD

# LLM Configuration
OPENAI_API_KEY=sk-your-key-here
# Or use local Ollama
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Document Archive Configuration
PROJECT_DOCS_PATH=C:\path\to\project\documents
FILE_EXTENSIONS=.pdf,.docx,.txt

# RAG Configuration
VECTOR_DB_PATH=./vector_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SIMILARITY_THRESHOLD=0.6

# Email Summary Configuration
SUMMARY_RECIPIENT_EMAIL=team@company.com
